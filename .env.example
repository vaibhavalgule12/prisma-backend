# Copy this to .env and fill in your values
# Never commit .env to version control

# ── Server ────────────────────────────────────────
PORT=8080

# ── PostgreSQL ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=prisma
DB_PASSWORD=prisma
DB_NAME=prismadb
DB_SSLMODE=disable

# ── ETL Scheduler ─────────────────────────────────
# Cron expression: weekdays at 6 PM (adjust to your timezone)
ETL_SCHEDULE=0 18 * * 1-5
